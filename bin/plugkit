#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
case "$(uname -s)" in
  Darwin) OS=darwin ;;
  MINGW*|MSYS*|CYGWIN*)
    case "$(uname -m)" in
      arm64|aarch64) exec "$DIR/plugkit-win32-arm64.exe" "$@" ;;
      *)             exec "$DIR/plugkit-win32-x64.exe" "$@" ;;
    esac ;;
  *) OS=linux ;;
esac
case "$(uname -m)" in
  arm64|aarch64) ARCH=arm64 ;;
  *)             ARCH=x64   ;;
esac
exec "$DIR/plugkit-$OS-$ARCH" "$@"
